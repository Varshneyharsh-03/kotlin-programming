package com.example.myapplication

class Employee(val name: String, val department: String) {
    var salary: Double = 0.0

    constructor(name: String, department: String, salary: Double) : this(name, department) {
        this.salary = salary
    }

    fun displayEmployee() {
        println(
            """
            name : $name,
            department : $department
            salary : $salary
        """.trimIndent()
        )
    }

    fun giveRaise(raise: Double) {
        if (raise > 0) {
            salary += raise
        }
    }
}


fun main() {
    val emp1: Employee = Employee("Harsh", "Online Ordering")
    val emp2: Employee = Employee("Saini", "Consumer Ordering", 700000.00)

    emp2.displayEmployee()
    emp1.displayEmployee()

    emp1.giveRaise(2000.0)
    emp1.displayEmployee()
}
