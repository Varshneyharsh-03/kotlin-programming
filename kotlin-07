package com.example.myapplication

fun main() {
    var balance : Double = 5000.0
    var isRunning : Boolean = true

    val choices = """
        1. Check Balance
        2. Deposit Money
        3. Withdraw Money
        4. Print Numbers 1 to 20 (use a for loop)
        5. Print Even Numbers from 2 to 50 (use step)
        6. Print Countdown from 10 to 1 (use downTo)
        7. Exit
    """.trimIndent()

    while(isRunning){
        println(choices)
        println("-----------------------")
        print("Please select a choice btw 1-7")
        val option : Int = readln().toInt()

        when(option){
            1-> {
                println("Your balance is : ${balance}")
            }
            2->{
                print("Enter the money to be deposited :")
                val deposit =  readln().toDouble()
                balance += deposit

                println("Money ${deposit} is deposited successfully")

            }
            3->{
                print("Enter money to be withdraw :")
                val withdraw : Double = readln().toDouble()
                
                if(balance >= withdraw){
                    balance -= withdraw
                    println("Money ${withdraw} is withdrawn successfully")
                }
                else{
                    println("You don't have sufficient balance")
                }
            }
            4->{
                println("Printing number from 1 to 20")
                for(num in 1..20){
                    println("$num ")
                }
            }
            5->{
                println("Printing even number from 2-50")
                for(num in 2..50 step 2){
                    println("$num ")
                }
            }
            6->{
                println("Printing numbers from 10 to 1")
                for(num in 10 downTo 1){
                    println("$num ")
                }
            }
            7->{
                println("Thank you for using our ATM.")
                isRunning = false
            }
        }
    }
}
